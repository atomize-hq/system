{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "$ref": "fields.schema.json#/$defs/title"
    },
    "severity": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "details": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "severity"
  ],
  "additionalProperties": false
}
