{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_id": {
      "const": "handbook.artifact.work-specification"
    },
    "schema_version": {
      "const": "1.0"
    },
    "record_id": {
      "$ref": "#/$defs/recordId"
    },
    "objective": {
      "$ref": "#/$defs/longText"
    },
    "scope": {
      "$ref": "#/$defs/shortTextList"
    },
    "non_goals": {
      "$ref": "#/$defs/optionalShortTextList"
    },
    "acceptance_criteria": {
      "$ref": "#/$defs/shortTextList"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review_ready",
        "approved",
        "active",
        "completed",
        "cancelled"
      ]
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "record_id",
    "objective",
    "scope",
    "non_goals",
    "acceptance_criteria",
    "status"
  ],
  "additionalProperties": false,
  "unevaluatedProperties": false,
  "$defs": {
    "shortText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[^\\u0000]+$"
    },
    "longText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8192,
      "pattern": "^[^\\u0000]+$"
    },
    "stableRef": {
      "type": "string",
      "minLength": 3,
      "maxLength": 320,
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*(?:\\.[a-z][a-z0-9]*(?:-[a-z0-9]+)*)+(?:@[0-9]+\\.[0-9]+\\.[0-9]+)?$"
    },
    "shortTextList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/shortText"
      },
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true
    },
    "optionalShortTextList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/shortText"
      },
      "minItems": 0,
      "maxItems": 64,
      "uniqueItems": true
    },
    "referenceList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stableRef"
      },
      "minItems": 0,
      "maxItems": 128,
      "uniqueItems": true
    },
    "nonEmptyReferenceList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stableRef"
      },
      "minItems": 1,
      "maxItems": 128,
      "uniqueItems": true
    },
    "recordId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 255,
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*(?:\\.[a-z][a-z0-9]*(?:-[a-z0-9]+)*)+$"
    }
  }
}
