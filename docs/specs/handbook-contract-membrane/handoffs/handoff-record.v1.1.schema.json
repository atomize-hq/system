{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://handbook.dev/schemas/handoff-record/v1.1.json",
  "title": "Handbook Session Handoff Record v1.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "handoff_id",
    "created_at_utc",
    "program_id",
    "phase_id",
    "slice_id",
    "packet_id",
    "session",
    "status",
    "active_resolution",
    "snapshot_refs",
    "semantic_refs",
    "objective",
    "authority_refs",
    "repo_state",
    "work_completed",
    "deliverables",
    "decisions",
    "findings",
    "blockers",
    "escalations",
    "validation",
    "pack_updates",
    "next_session",
    "supersedes",
    "chat_summary"
  ],
  "properties": {
    "schema_id": {
      "const": "handbook.session-handoff"
    },
    "schema_version": {
      "const": "1.1"
    },
    "handoff_id": {
      "type": "string",
      "minLength": 8,
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "program_id": {
      "const": "handbook-contract-membrane"
    },
    "phase_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "slice_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "packet_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "agent",
        "thread_ref"
      ],
      "properties": {
        "kind": {
          "enum": [
            "orchestration",
            "design",
            "planning",
            "documentation",
            "implementation",
            "review",
            "proof"
          ]
        },
        "agent": {
          "type": "string",
          "minLength": 1
        },
        "thread_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "status": {
      "enum": [
        "completed",
        "partial",
        "blocked",
        "escalation_required",
        "review_required",
        "superseded"
      ]
    },
    "active_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "scope_horizon",
        "detail_resolution",
        "temporal_horizon",
        "authority_horizon",
        "memory_horizon",
        "validation_horizon"
      ],
      "properties": {
        "level": {
          "type": "string",
          "minLength": 1
        },
        "scope_horizon": {
          "type": "string",
          "minLength": 1
        },
        "detail_resolution": {
          "type": "string",
          "minLength": 1
        },
        "temporal_horizon": {
          "type": "string",
          "minLength": 1
        },
        "authority_horizon": {
          "type": "string",
          "minLength": 1
        },
        "memory_horizon": {
          "type": "string",
          "minLength": 1
        },
        "validation_horizon": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "snapshot_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capture_status",
        "prior_end_snapshot_ref",
        "session_start_snapshot_ref",
        "grounding_delta_ref",
        "grounding_projection_ref",
        "session_end_snapshot_ref",
        "session_delta_ref"
      ],
      "properties": {
        "capture_status": {
          "enum": [
            "not_available",
            "captured",
            "partial",
            "failed"
          ]
        },
        "prior_end_snapshot_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "session_start_snapshot_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "grounding_delta_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "grounding_projection_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "session_end_snapshot_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "session_delta_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "semantic_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_kind_refs",
        "artifact_instance_refs",
        "intake_definition_refs",
        "intake_record_refs",
        "artifact_candidate_refs",
        "canonical_artifact_refs",
        "posture_kernel_ref",
        "posture_recommendation_refs",
        "posture_transition_refs",
        "default_set_decision_ref"
      ],
      "properties": {
        "artifact_kind_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifact_instance_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "intake_definition_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "intake_record_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifact_candidate_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonical_artifact_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "posture_kernel_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "posture_recommendation_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "posture_transition_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "default_set_decision_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "authority_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pathSections"
      }
    },
    "repo_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch",
        "head",
        "dirty",
        "changed_paths"
      ],
      "properties": {
        "branch": {
          "type": "string"
        },
        "head": {
          "type": "string"
        },
        "dirty": {
          "type": "boolean"
        },
        "changed_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "work_completed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "status",
          "summary"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "status": {
            "enum": [
              "completed",
              "partial",
              "blocked",
              "not_started",
              "superseded"
            ]
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decision_id",
          "summary",
          "authority_effect",
          "refs"
        ],
        "properties": {
          "decision_id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "authority_effect": {
            "type": "string"
          },
          "refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "classification",
          "severity",
          "summary",
          "evidence_refs"
        ],
        "properties": {
          "finding_id": {
            "type": "string"
          },
          "classification": {
            "enum": [
              "local_remediation",
              "child_packet_required",
              "cross_document_repair",
              "resolution_escalation",
              "external_blocker",
              "proof_gap",
              "future_program"
            ]
          },
          "severity": {
            "enum": [
              "info",
              "warning",
              "major",
              "critical"
            ]
          },
          "summary": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "blocker_id",
          "classification",
          "summary",
          "resume_condition",
          "owner"
        ],
        "properties": {
          "blocker_id": {
            "type": "string"
          },
          "classification": {
            "enum": [
              "local",
              "external",
              "authority",
              "documentation",
              "proof"
            ]
          },
          "summary": {
            "type": "string"
          },
          "resume_condition": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          }
        }
      }
    },
    "escalations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "escalation_id",
          "trigger",
          "current_resolution",
          "target_resolution",
          "decision_required",
          "options",
          "recommendation",
          "affected_refs",
          "preserve_current_work",
          "resume_condition"
        ],
        "properties": {
          "escalation_id": {
            "type": "string"
          },
          "trigger": {
            "type": "string"
          },
          "current_resolution": {
            "type": "string"
          },
          "target_resolution": {
            "type": "string"
          },
          "decision_required": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "recommendation": {
            "type": "string"
          },
          "affected_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "preserve_current_work": {
            "type": "boolean"
          },
          "resume_condition": {
            "type": "string"
          }
        }
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "status",
          "evidence_ref"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "status": {
            "enum": [
              "passed",
              "failed",
              "blocked",
              "not_run"
            ]
          },
          "evidence_ref": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "pack_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sections",
          "reason",
          "status"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sections": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reason": {
            "type": "string"
          },
          "status": {
            "enum": [
              "required",
              "completed",
              "deferred"
            ]
          }
        }
      }
    },
    "next_session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommended_kind",
        "objective",
        "dispatch_required",
        "must_read",
        "allowed_scope",
        "prohibited_scope",
        "acceptance_criteria",
        "stop_conditions"
      ],
      "properties": {
        "recommended_kind": {
          "enum": [
            "orchestration",
            "design",
            "planning",
            "documentation",
            "implementation",
            "review",
            "proof",
            "none"
          ]
        },
        "objective": {
          "type": "string"
        },
        "dispatch_required": {
          "type": "boolean"
        },
        "must_read": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pathSections"
          }
        },
        "allowed_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prohibited_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stop_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "chat_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 600
    }
  },
  "$defs": {
    "pathSections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sections"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
