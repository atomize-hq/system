{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://handbook.dev/schemas/handoff-ledger-entry/v1.json",
  "title": "Handbook Handoff Ledger Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "handoff_id",
    "created_at_utc",
    "status",
    "session_kind",
    "phase_id",
    "slice_id",
    "packet_id",
    "record_path"
  ],
  "properties": {
    "schema_id": { "const": "handbook.handoff-ledger-entry" },
    "schema_version": { "const": "1.0" },
    "handoff_id": { "type": "string", "minLength": 8 },
    "created_at_utc": { "type": "string", "format": "date-time" },
    "status": {
      "enum": [
        "completed",
        "partial",
        "blocked",
        "escalation_required",
        "review_required",
        "superseded"
      ]
    },
    "session_kind": {
      "enum": [
        "orchestration",
        "design",
        "planning",
        "documentation",
        "implementation",
        "review",
        "proof"
      ]
    },
    "phase_id": { "type": ["string", "null"] },
    "slice_id": { "type": ["string", "null"] },
    "packet_id": { "type": ["string", "null"] },
    "record_path": { "type": "string", "minLength": 1 }
  }
}
