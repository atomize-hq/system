{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://handbook.dev/schemas/internal-dispatch/v1.0.json",
  "title": "Handbook Internal Subagent Dispatch v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "dispatch_id",
    "created_at_utc",
    "source_handoff_ids",
    "parent_orchestration_id",
    "orchestration_decision",
    "execution_target",
    "agent_type",
    "role",
    "fresh_context_required",
    "closeout_owner",
    "required_skills",
    "phase_id",
    "slice_id",
    "packet_id",
    "subject_fingerprint",
    "active_resolution",
    "authority_refs",
    "repo_truth",
    "allowed_scope",
    "non_goals",
    "tasks",
    "contracts_and_gates",
    "stop_conditions",
    "return_contract"
  ],
  "properties": {
    "schema_id": {
      "const": "handbook.internal-dispatch"
    },
    "schema_version": {
      "const": "1.0"
    },
    "dispatch_id": {
      "type": "string",
      "minLength": 8,
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "source_handoff_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 8
      },
      "uniqueItems": true
    },
    "parent_orchestration_id": {
      "type": "string",
      "minLength": 8
    },
    "orchestration_decision": {
      "enum": [
        "resume_same_packet",
        "local_remediation_packet",
        "child_packet_required",
        "cross_document_repair",
        "resolution_escalation",
        "external_blocker_followup",
        "proof_or_review_followup",
        "advance_to_next_slice",
        "defer_future_program"
      ]
    },
    "execution_target": {
      "const": "internal_subagent"
    },
    "agent_type": {
      "const": "default"
    },
    "role": {
      "enum": [
        "implementation",
        "documentation",
        "review",
        "proof",
        "remediation"
      ]
    },
    "fresh_context_required": {
      "const": true
    },
    "closeout_owner": {
      "const": "parent_orchestrator"
    },
    "required_skills": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "phase_id": {
      "type": "string",
      "minLength": 1
    },
    "slice_id": {
      "type": "string",
      "minLength": 1
    },
    "packet_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "subject_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "active_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "scope_horizon",
        "detail_resolution",
        "temporal_horizon",
        "authority_horizon",
        "memory_horizon",
        "validation_horizon"
      ],
      "properties": {
        "level": {
          "type": "string",
          "minLength": 1
        },
        "scope_horizon": {
          "type": "string",
          "minLength": 1
        },
        "detail_resolution": {
          "type": "string",
          "minLength": 1
        },
        "temporal_horizon": {
          "type": "string",
          "minLength": 1
        },
        "authority_horizon": {
          "type": "string",
          "minLength": 1
        },
        "memory_horizon": {
          "type": "string",
          "minLength": 1
        },
        "validation_horizon": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "authority_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pathSections"
      },
      "minItems": 1
    },
    "repo_truth": {
      "type": "string",
      "minLength": 1
    },
    "allowed_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "contracts_and_gates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "return_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transport",
        "findings_first",
        "include_agent_identity_and_status",
        "edit_scope",
        "global_handoff",
        "ledger_write",
        "user_task_hop",
        "required_result_fields"
      ],
      "properties": {
        "transport": {
          "const": "built_in_subagent"
        },
        "findings_first": {
          "type": "boolean"
        },
        "include_agent_identity_and_status": {
          "const": true
        },
        "edit_scope": {
          "enum": [
            "read_only",
            "bounded_write"
          ]
        },
        "global_handoff": {
          "const": "forbidden"
        },
        "ledger_write": {
          "const": "forbidden"
        },
        "user_task_hop": {
          "const": "forbidden"
        },
        "required_result_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "role": {
            "const": "review"
          }
        },
        "required": [
          "role"
        ]
      },
      "then": {
        "properties": {
          "required_skills": {
            "contains": {
              "const": "code-review-and-quality"
            },
            "minContains": 1
          },
          "return_contract": {
            "properties": {
              "findings_first": {
                "const": true
              },
              "edit_scope": {
                "const": "read_only"
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "pathSections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sections"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
